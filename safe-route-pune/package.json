{
  "name": "pune-safe-route",
  "version": "1.0.0",
  "description": "AI-powered safe route navigation for Pune — analyzes crime, accidents, lighting & crowd-sourced data",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "generate-data": "cd ml && python generate_dataset.py",
    "train": "cd ml && python train_model.py",
    "setup": "npm install && node src/setup.js"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "lowdb": "^1.0.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
